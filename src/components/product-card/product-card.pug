mixin productCard(payload)
    .product-card
        .product-card__top
            img.product-card__image(src=payload.image)
            .product-card__actions
                .product-card__tags
                    if payload.sale
                        .product-card__tag.product-card__tag-sale= payload.sale
                    if payload.available
                        .product-card__tag.product-card__tag-available= payload.available
                .product-card__buttons
                    button.product-card__button.product-card__button-favorite
                        svg(width="28" height="28" viewBox="0 0 28 28" xmlns="http://www.w3.org/2000/svg")
                            path(d="M5.19242 16.2261L13.3153 23.8567C13.6397 24.1614 13.8019 24.3138 14 24.3138C14.198 24.3138 14.3602 24.1614 14.6846 23.8567L22.8075 16.2261C25.0897 14.0822 25.3669 10.5542 23.4474 8.08025L23.0865 7.61507C20.7903 4.65552 16.1812 5.15185 14.5677 8.53243C14.3398 9.00996 13.6601 9.00996 13.4322 8.53243C11.8187 5.15185 7.20964 4.65551 4.91343 7.61507L4.55251 8.08025C2.63307 10.5542 2.91021 14.0822 5.19242 16.2261Z" stroke-width="2")
        .product-card__name= payload.name
        .product-card__price
            .product-card__price-default
                span= payload.price
                |  руб.
            .product-card__price-old
                del= payload.priceOld
                |  руб.
        +button('В корзину', { variant: 'primary' })