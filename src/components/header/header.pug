    //- Миксин для пункта меню с выпадающим списком
    mixin menuItem(item)
        .header__menu-item
            a(href=item.href).header__menu-link= item.title
            if item.items && item.items.length > 0
                .header__dropdown
                    each subItem in item.items
                        a(href=subItem.href).header__dropdown-link= subItem.title

    .header__bottom
        .header__container
            nav.header__menu
                each menuItem in menuItems
                    +menuItem(menuItem)
            .header__inner
                include ../search/search
                +button('Заказать звонок', { variant: 'primary' }).header__callback-button
